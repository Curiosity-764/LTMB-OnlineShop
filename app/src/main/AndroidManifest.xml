<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet permission for Firebase -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LTMBOnlineShop">

        <!-- Auth Activity as LAUNCHER (No parent) -->
        <activity
            android:name=".activities.AuthActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ProductListActivity - Parent is AuthActivity -->
        <activity
            android:name=".activities.ProductListActivity"
            android:parentActivityName=".activities.AuthActivity"
            android:exported="false" />

        <!-- AdminActivity - Parent is ProductListActivity -->
        <activity
            android:name=".activities.AdminActivity"
            android:parentActivityName=".activities.ProductListActivity"
            android:exported="false" />

        <!-- ProfileActivity - Parent is ProductListActivity -->
        <activity
            android:name=".activities.ProfileActivity"
            android:parentActivityName=".activities.ProductListActivity"
            android:exported="false" />

        <!-- Future Activities - Parent is ProductListActivity -->
        <activity
            android:name=".activities.Checkout"
            android:parentActivityName=".activities.ProductListActivity"
            android:exported="false" />

        <activity
            android:name=".activities.Cart"
            android:parentActivityName=".activities.ProductListActivity"
            android:exported="false" />

        <activity
            android:name=".activities.CartItem"
            android:parentActivityName=".activities.ProductListActivity"
            android:exported="false" />

        <activity
            android:name=".activities.ProductDetail"
            android:parentActivityName=".activities.ProductListActivity"
            android:exported="false" />

        <activity
            android:name=".activities.ProductItem"
            android:parentActivityName=".activities.ProductListActivity"
            android:exported="false" />

        <activity
            android:name=".activities.SplashActivity"
            android:parentActivityName=".activities.AuthActivity"
            android:exported="false" />

    </application>

</manifest>